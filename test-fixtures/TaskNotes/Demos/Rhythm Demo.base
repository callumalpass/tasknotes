filters:
  and:
    - or:
        - file.hasTag("task")
        - isTask == true
    - tnType != "base-notification"
    - recurrence
    - !recurrence.isEmpty()
formulas:
  recurrenceType: if(recurrence.contains("DAILY"), "Daily", if(recurrence.contains("WEEKLY"), "Weekly", if(recurrence.contains("MONTHLY"), "Monthly", if(recurrence.contains("YEARLY"), "Yearly", "Other"))))
  completionCount: if(complete_instances, list(complete_instances).length, 0)
  isCompletedToday: complete_instances && list(complete_instances).contains(today().format("yyyy-MM-dd"))
  daysUntilDue: if(due, ((number(date(due)) - number(today())) / 86400000).floor(), null)
  streakStatus: if(formula.isCompletedToday, "Done today", if(formula.completionCount > 0, "Active streak", "Not started"))
  assigneeName: if(assignee, assignee.replace("[[", "").replace("]]", ""), "Unassigned")
properties:
  title:
    displayName: Habit / Routine
  formula.recurrenceType:
    displayName: Frequency
  formula.completionCount:
    displayName: Completions
  formula.streakStatus:
    displayName: Today
  scheduled:
    displayName: Scheduled
  due:
    displayName: Next Due
  formula.assigneeName:
    displayName: Owner
views:
  - type: tasknotesTaskList
    name: All Rhythms
    order:
      - title
      - formula.recurrenceType
      - formula.completionCount
      - formula.streakStatus
      - scheduled
    sort:
      - property: formula.recurrenceType
        direction: ASC
    enableSearch: true
  - type: table
    name: By Frequency
    order:
      - title
      - formula.completionCount
      - formula.streakStatus
      - scheduled
    sort:
      - property: formula.completionCount
        direction: DESC
    group:
      - column: formula.recurrenceType
  - type: tasknotesCalendar
    name: Completion Calendar
    order:
      - title
      - formula.recurrenceType
      - formula.streakStatus
  - type: table
    name: Today's Rhythms
    filters:
      and:
        - or:
            - scheduled && date(scheduled).date() == today()
            - due && date(due).date() == today()
            - formula.recurrenceType == "Daily"
    order:
      - title
      - formula.streakStatus
      - formula.completionCount
      - formula.recurrenceType
    sort:
      - property: title
        direction: ASC
