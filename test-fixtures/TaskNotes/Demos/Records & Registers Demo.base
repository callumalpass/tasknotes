filters:
  and:
    - file.inFolder("Document Library, Knowledge")
    - type == "document"
    - status == "active"
formulas:
  daysUntilReview: "review_date ? ((number(date(review_date)) - number(today())) / 86400000).floor() : 999"
  isOverdue: formula.daysUntilReview < 0
  isDueSoon: formula.daysUntilReview >= 0 && formula.daysUntilReview <= 14
  reviewStatus: if(formula.daysUntilReview < 0, "OVERDUE", if(formula.daysUntilReview <= 7, "Due this week", if(formula.daysUntilReview <= 30, "Due this month", "OK")))
  ownerName: if(control_owner, control_owner.replace("[[", "").replace("]]", ""), if(owner, owner.replace("[[", "").replace("]]", ""), "Unassigned"))
  cycleDays: if(review_cycle == "quarterly", 90, if(review_cycle == "monthly", 30, if(review_cycle == "annual", 365, if(review_cycle == "semi-annual", 182, 0))))
properties:
  file.name:
    displayName: Document
  formula.reviewStatus:
    displayName: Review Status
  formula.ownerName:
    displayName: Owner
  review_date:
    displayName: Next Review
  last_reviewed:
    displayName: Last Reviewed
  review_cycle:
    displayName: Cycle
  department:
    displayName: Department
  formula.daysUntilReview:
    displayName: Days Until Review
views:
  - type: table
    name: Register — Needs Attention
    filters:
      and:
        - or:
            - formula.isOverdue
            - formula.isDueSoon
    order:
      - formula.reviewStatus
      - file.name
      - formula.ownerName
      - review_date
      - review_cycle
      - department
    sort:
      - property: formula.daysUntilReview
        direction: ASC
    notify: true
  - type: table
    name: Register — Full
    order:
      - file.name
      - formula.reviewStatus
      - formula.daysUntilReview
      - formula.ownerName
      - review_date
      - review_cycle
      - department
    sort:
      - property: formula.daysUntilReview
        direction: ASC
  - type: table
    name: By Owner
    order:
      - formula.ownerName
      - file.name
      - formula.reviewStatus
      - formula.daysUntilReview
      - review_cycle
    sort:
      - property: formula.daysUntilReview
        direction: ASC
    group:
      - column: formula.ownerName
  - type: table
    name: By Department
    order:
      - department
      - file.name
      - formula.reviewStatus
      - formula.ownerName
      - review_date
    sort:
      - property: formula.daysUntilReview
        direction: ASC
    group:
      - column: department
